# --- Claude Code tooling (local only) ---
.claude/

# --- Data & Secrets ---
data/*
!data/users/
data/users/*
!data/users/default/
.env
*.env.*
!.env.example
.streamlit/secrets.toml

# --- Local LLM runtime artifacts ---
.ollama/
ollama/

# --- Python cache & compiled ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --- Virtual environment ---
.venv/
venv/
env/

# --- Build & distribution ---
dist/
build/
*.egg-info/
*.egg

# --- Test & coverage artifacts ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
test_output.txt

# --- Type checker & linting cache ---
.mypy_cache/
.ruff_cache/

# --- Logs & output ---
logs/
output/*
!output/default/
output/default/*.gz
*.log

# --- Project-specific runtime cache ---
src/cache/
src/data/processed/

# --- Jupyter ---
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# --- OS & editor junk ---
.DS_Store
Thumbs.db
.vscode/settings.json
