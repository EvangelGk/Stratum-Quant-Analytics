# ─────────────────────────────────────────────────────────────────────────────
# Scenario Planner — Environment Configuration Template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Runtime Mode ──────────────────────────────────────────────────────────────
# "sample"  → 2 tickers (AAPL, F)  — fast, for development & testing
# "actual"  → 5 tickers (AAPL, TSLA, MSFT, WMT, XOM) — full production run
ENVIRONMENT=sample

# ── Date Range ────────────────────────────────────────────────────────────────
START_DATE=2016-01-01
END_DATE=2026-12-31

# ── Performance Tuning ────────────────────────────────────────────────────────
MAX_WORKERS=10
MAX_RETRIES=4
RETRY_DELAY_MIN=1.0
RETRY_DELAY_MAX=3.0

# ── Reproducibility Policy ───────────────────────────────────────────────────
# RANDOM_SEED is used by stochastic analyses (e.g., Monte Carlo).
RANDOM_SEED=42
# If true, stochastic modules must run with deterministic seeds where supported.
ENFORCE_REPRODUCIBILITY=true

# ── Governance Policy (Hard Fail Gates) ─────────────────────────────────────
# If true, advanced analyses are blocked when governance gate fails.
GOVERNANCE_HARD_FAIL=true
# Minimum acceptable out-of-sample R2.
GOVERNANCE_MIN_R2=-0.25
# Maximum allowed normalized mean shift between train/test.
GOVERNANCE_MAX_NORMALIZED_SHIFT=2.5
# Maximum number of leakage flags tolerated.
GOVERNANCE_MAX_LEAKAGE_FLAGS=1
# Minimum stationary-series ratio (0.0 to 1.0).
GOVERNANCE_MIN_STATIONARY_RATIO=0.4
# Number of walk-forward windows for governance backtesting.
GOVERNANCE_WALK_FORWARD_WINDOWS=4
# Minimum acceptable walk-forward average R2.
GOVERNANCE_MIN_WALK_FORWARD_R2=-0.25
# Maximum allowed composite model risk score (0.0 to 1.0).
GOVERNANCE_MAX_MODEL_RISK_SCORE=0.6

# ── Optional Code Lineage ────────────────────────────────────────────────────
# Set this in CI/CD for code provenance in run-contract logs.
# GIT_COMMIT_SHA=<commit-sha>
