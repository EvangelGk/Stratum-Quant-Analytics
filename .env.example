# ─────────────────────────────────────────────────────────────────────────────
# Scenario Planner — Environment Configuration Template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Runtime Mode ──────────────────────────────────────────────────────────────
# "sample"  → 2 tickers (AAPL, F)  — fast, for development & testing
# "actual"  → 5 tickers (AAPL, TSLA, MSFT, WMT, XOM) — full production run
ENVIRONMENT=sample

# Optional explicit ticker universe (CSV or JSON list).
# If set, overrides SAMPLE/ACTUAL defaults and pulls all listed symbols from yfinance.
# Example: TARGET_TICKERS=AAPL,MSFT,TSLA,NVDA,AMZN,GOOGL
# Example: TARGET_TICKERS=["AAPL","MSFT","TSLA"]
# TARGET_TICKERS=

# Per-user storage namespace (all run artifacts under data/users/<DATA_USER_ID>/)
DATA_USER_ID=default

# ── Date Range ────────────────────────────────────────────────────────────────
START_DATE=2016-01-01
END_DATE=2026-12-31

# ── Performance Tuning ────────────────────────────────────────────────────────
MAX_WORKERS=10
MAX_RETRIES=4
RETRY_DELAY_MIN=1.0
RETRY_DELAY_MAX=3.0

# ── Reproducibility Policy ───────────────────────────────────────────────────
# RANDOM_SEED is used by stochastic analyses (e.g., Monte Carlo).
RANDOM_SEED=42
# If true, stochastic modules must run with deterministic seeds where supported.
ENFORCE_REPRODUCIBILITY=true

# ── Silver Guardrails ────────────────────────────────────────────────────────
# If true, Silver quality failures stop the pipeline.
SILVER_HARD_FAIL=true
# Minimum rows required per entity in Silver preflight checks.
SILVER_MIN_ROWS=10
# Minimum observed/expected rows ratio (0.0 to 1.0).
SILVER_MIN_ROWS_RATIO=0.1
# Base null threshold (%) for dynamic null gating.
SILVER_BASE_NULL_THRESHOLD=30.0
# Rolling history window for adaptive null-threshold calculation.
SILVER_DYNAMIC_THRESHOLD_WINDOW=20
# Additional buffer between warning and hard-fail null thresholds.
SILVER_WARN_TO_FAIL_BUFFER=15.0
# Warn when outlier clipping ratio exceeds this fraction (0.0 to 1.0).
SILVER_OUTLIER_WARNING_RATIO=0.1

# ── Governance Policy (Hard Fail Gates) ─────────────────────────────────────
# If true, advanced analyses are blocked when governance gate fails.
GOVERNANCE_HARD_FAIL=true
# Minimum acceptable out-of-sample R2.
GOVERNANCE_MIN_R2=0.0
# Maximum allowed normalized mean shift between train/test.
GOVERNANCE_MAX_NORMALIZED_SHIFT=2.5
# Maximum number of leakage flags tolerated.
GOVERNANCE_MAX_LEAKAGE_FLAGS=1
# Minimum stationary-series ratio (0.0 to 1.0).
GOVERNANCE_MIN_STATIONARY_RATIO=0.4
# Number of walk-forward windows for governance backtesting.
GOVERNANCE_WALK_FORWARD_WINDOWS=4
# Minimum acceptable walk-forward average R2.
GOVERNANCE_MIN_WALK_FORWARD_R2=0.0
# Very negative raw walk-forward values are treated as unstable metrics.
GOVERNANCE_UNSTABLE_WALK_FORWARD_FLOOR=-5.0
# Clipping floor used in governance walk-forward robustness scoring.
GOVERNANCE_CLIPPED_WALK_FORWARD_FLOOR=-2.0
# Maximum allowed composite model risk score (0.0 to 1.0).
GOVERNANCE_MAX_MODEL_RISK_SCORE=0.6
# Regime profile: normal, stress, or crisis.
GOVERNANCE_REGIME=normal
# Model-risk score band thresholds for PASS/WARN/FAIL labeling.
GOVERNANCE_MODEL_RISK_WARN_THRESHOLD=0.4
GOVERNANCE_MODEL_RISK_FAIL_THRESHOLD=0.6

# ── Optional Code Lineage ────────────────────────────────────────────────────
# Set this in CI/CD for code provenance in run-contract logs.
# GIT_COMMIT_SHA=<commit-sha>

# ── Per-Ticker Governance Overrides (optional) ───────────────────────────────
# JSON map of per-ticker threshold overrides applied before regime multipliers.
# Example: GOVERNANCE_TICKER_OVERRIDES={"TSLA": {"min_r2": 0.1}}
# GOVERNANCE_TICKER_OVERRIDES=

# ── Optional Source Registry Overrides (JSON maps) ──────────────────────────
# Example: MACRO_SERIES_MAP={"CPIAUCSL":"inflation","UNRATE":"unemployment_rate"}
# MACRO_SERIES_MAP=
# Example: WORLDBANK_INDICATOR_MAP={"NY.GDP.MKTP.KD.ZG":"gdp_growth","SL.UEM.TOTL.ZS":"unemployment_wb"}
# WORLDBANK_INDICATOR_MAP=

# ── World Bank Multi-Economy Controls ───────────────────────────────────────
# ISO-3 codes, comma-separated. Example: WLD,GRC,DEU,USA
WORLDBANK_ECONOMIES=WLD
# Aggregation strategy before Gold merge: mean | median | sum | last
WORLDBANK_AGGREGATION_STRATEGY=mean

# ── Analysis Toggles ─────────────────────────────────────────────────────────
# Enable Auto-ML analysis output (heavier runtime/dependencies).
AUTO_ML_ENABLED=false

# ── Auditor Controls ─────────────────────────────────────────────────────────
# Allowed business-day gap threshold in temporal continuity audit.
AUDITOR_ALLOWED_GAP_DAYS=7

# ── Mobile Notifications (Telegram) ──────────────────────────────────────────
# ⚠️  SENSITIVE — never commit real values. Fill these in your local .env only.
#
# 1. Create a bot via @BotFather on Telegram → copy the token it gives you.
# 2. Send any message to your new bot, then open:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Look for "chat" → "id" in the JSON response — that is your TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional generic webhook (ntfy.sh, Pushover, Zapier, etc.)
# MOBILE_NOTIFY_WEBHOOK_URL=

# ── AI Agent / Ollama ─────────────────────────────────────────────────────────
# Override only if Ollama runs on a non-default host or port.
# OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=llama3.2:1b
# Generation timeout in seconds (default 300). Increase if you get Read timed out.
# OLLAMA_TIMEOUT=300
# Human-approval gate timeout in seconds (default 300).
# APPROVAL_TIMEOUT=300
# Mandatory test-suite timeout in seconds (default 300).
# TEST_TIMEOUT=300

# ── AI Agent / Google Gemini (online fallback) ────────────────────────────────
# Used automatically when Ollama is NOT reachable (e.g. cloud/hosted deployments).
#
# Get your free key at: https://aistudio.google.com/app/apikey
# ⚠️  SENSITIVE — never commit a real key here.
#     For local runs: fill in below.
#     For Streamlit Cloud: set via the Streamlit secrets dashboard instead.
#
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Optimizer (Owner-only) ────────────────────────────────────────────────────
# Uncomment to enable the optimizer section in the UI sidebar.
# OPTIMIZER_OWNER_MODE=1
# OPTIMIZER_TARGET_SCORE=94
# OPTIMIZER_MAX_ITERATIONS=8
# LLAMA_MANDATORY_TEST_CMD=pytest -q tests/
